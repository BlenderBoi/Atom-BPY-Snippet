  'Register':
    'prefix': 'register'
    'body':"""

classes = [$1]

def register():

    for cls in classes:
        bpy.utils.register_class(cls)


def unregister():

    for cls in classes:
        bpy.utils.unregister_class(cls)


if __name__ == "__main__":
    register()

    """

  'Class Function:Variable: Enum':
    'prefix': 'enum_var'
    'body':"""ENUM_${1:Item} = [("$2","$3","$4"),("$5","$6","$7")]"""


  'Class Function:Class: Operator (Full)':
    'prefix': 'operator_cls'
    'body':'''
class ${1:ADDON}_OT_${2:Addon_Operator}(bpy.types.Operator):
    """Addon Operator"""
    bl_idname = "${3:addon}.${4:operator}"
    bl_label = "${5:Addon Operator}"
    bl_options = {'REGISTER', 'UNDO'}

    @classmethod
    def poll(cls, context):
        return True

    def draw(self, context):
        layout = self.layout

    def invoke(self, context, event):

        return self.execute(context)

    def execute(self, context):

        return {'FINISHED'}
    '''



