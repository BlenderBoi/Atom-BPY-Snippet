  'Class Function: Init':
    'prefix': 'init'
    'body':'''


import bpy

modules = [$1]

def register():

    for module in modules:
        module.register()

def unregister():

    for module in modules:
        module.unregister()

if __name__ == "__main__":
    register()

    '''


